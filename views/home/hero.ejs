<section class="w-full px-6 mt-2">

    <div class="relative max-w-7xl mx-auto h-[640px] rounded-[40px] overflow-hidden">


        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
            class="w-3 h-3 text-white">

            <path stroke-linecap="round" stroke-linejoin="round" d="m12.75 15 3-3m0 0-3-3m3 3h-7.5" />

        </svg>


        <div class="absolute inset-0 bg-black/25"></div>


        <div class="absolute top-[40px] left-1/2 -translate-x-1/2 z-10">

            <h1 class="text-[150px] font-bold text-white/25 leading-none whitespace-nowrap tracking-wide">
                REAL ESTATE
            </h1>
        </div>


        <div class="absolute inset-0 flex flex-col items-center justify-center z-20 px-4 pt-10">


            <h2 class="text-white text-[64px] font-semibold text-center leading-tight">

                Find A House That Suits You

            </h2>


            <p class="mt-5 text-white/80 text-[18px] text-center max-w-2xl leading-relaxed">

                Discover premium properties, trusted agents, and hassle-free
                buying experience.

            </p>

            <form action="/properties" method="GET"
                class="mt-14 bg-white rounded-full shadow-2xl h-[78px] px-4 flex items-center gap-4">


                <select name="purpose"
                    class="h-[52px] px-5 rounded-full bg-gray-100 text-gray-700 text-sm outline-none cursor-pointer">

                    <option value="buy">
                        Buy
                    </option>

                    <option value="rent">
                        Rent
                    </option>

                </select>

                <div class="flex items-center gap-3 h-[52px] w-[260px] px-5 rounded-full border border-gray-200">

                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                        stroke="currentColor" class="w-5 h-5 text-gray-400">

                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 5.5 5.5a7.5 7.5 0 0 0 11.15 11.15Z" />

                    </svg>

                    <input type="text" name="keyword" placeholder="Search Keyword"
                        class="w-full outline-none text-sm text-gray-700 placeholder:text-gray-400" />

                </div>


                <select name="type"
                    class="h-[52px] px-6 rounded-full border border-gray-200 text-gray-500 text-sm outline-none cursor-pointer">

                    <option value="">
                        Type
                    </option>

                    <option value="apartment">
                        Apartment
                    </option>

                    <option value="villa">
                        Villa
                    </option>

                    <option value="office">
                        Office
                    </option>

                    <option value="commercial">
                        Commercial
                    </option>

                </select>

                
                <select name="city"
                    class="h-[52px] px-6 rounded-full border border-gray-200 text-gray-500 text-sm outline-none cursor-pointer">

                    <option value="">
                        All Cities
                    </option>

                    <option value="mumbai">
                        Mumbai
                    </option>

                    <option value="delhi">
                        Delhi
                    </option>

                    <option value="bangalore">
                        Bangalore
                    </option>

                    <option value="hyderabad">
                        Hyderabad
                    </option>

                </select>

               
                <button type="submit"
                    class="w-[52px] h-[52px] rounded-full bg-purple-500 hover:bg-purple-600 transition flex items-center justify-center">

                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                        stroke="currentColor" class="w-5 h-5 text-white">

                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 5.5 5.5a7.5 7.5 0 0 0 11.15 11.15Z" />

                    </svg>

                </button>

            </form>

        </div>

       
        <div class="absolute right-[-70px] top-1/2 -translate-y-1/2 rotate-90 z-30">

            <button
                class="bg-purple-500 text-white px-7 py-4 rounded-t-3xl rounded-b-3xl text-sm font-medium shadow-lg">

                Schedule a Free Consultation

            </button>

        </div>

    </div>

</section>