<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Real Estate – Sign In</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet" />
    <style>
        body {
            font-family: 'DM Sans', sans-serif;
        }

        h1,
        .brand {
            font-family: 'Playfair Display', serif;
        }

        .hero-bg {
            background: linear-gradient(135deg, #0a0a2e 0%, #0d1b6e 30%, #1a0050 60%, #05102a 100%);
            position: relative;
            overflow: hidden;
        }

        .hero-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 30% 60%, rgba(99, 60, 255, 0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(30, 80, 220, 0.2) 0%, transparent 50%);
            animation: pulse-glow 6s ease-in-out infinite alternate;
        }

        .hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        @keyframes pulse-glow {
            0% {
                opacity: 0.7;
            }

            100% {
                opacity: 1;
            }
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(70px);
            opacity: 0.15;
            animation: float 8s ease-in-out infinite;
        }

        .blob-1 {
            width: 350px;
            height: 350px;
            background: #6c3cff;
            top: 10%;
            left: -5%;
            animation-delay: 0s;
        }

        .blob-2 {
            width: 250px;
            height: 250px;
            background: #1e50dc;
            bottom: 20%;
            left: 20%;
            animation-delay: 3s;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-30px);
            }
        }

        .field-input:focus {
            outline: none;
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.12);
        }

        .btn-signin {
            background: linear-gradient(90deg, #7c3aed, #6d28d9);
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .btn-signin::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
            transition: left 0.5s ease;
        }

        .btn-signin:hover::after {
            left: 100%;
        }

        .btn-signin:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 25px rgba(124, 58, 237, 0.4);
        }

        .social-btn {
            transition: all 0.2s ease;
            border: 1.5px solid #e5e7eb;
        }

        .social-btn:hover {
            border-color: #7c3aed;
            background: #f5f3ff;
            transform: translateY(-1px);
        }

        .card-enter {
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-text {
            animation: fadeIn 1s ease 0.2s both;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .or-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #9ca3af;
            font-size: 0.8rem;
            margin: 16px 0;
        }

        .or-divider::before,
        .or-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e5e7eb;
        }

        /* Testimonial card */
        .testimonial-card {
            background: rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1.25rem;
            padding: 1.25rem 1.5rem;
            animation: fadeIn 1s ease 0.5s both;
        }

        /* Stat cards */
        .stat-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
            padding: 0.85rem 1.25rem;
            animation: fadeIn 1s ease 0.6s both;
        }

        /* Checkbox custom */
        input[type="checkbox"]:checked {
            accent-color: #7c3aed;
        }
    </style>
</head>

<body class="min-h-screen flex">

    <!-- LEFT: Hero Panel -->
    <div class="hero-bg relative hidden md:flex flex-col justify-between flex-1 p-10 text-white">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>

        <!-- Brand -->
        <div class="relative z-10 hero-text">
            <span class="brand text-2xl font-bold tracking-tight">Real Estate</span>
        </div>

        <!-- Back to home -->
        <a href="#"
            class="absolute top-6 right-8 text-sm text-white/70 hover:text-white transition z-10 flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to home
        </a>

        <!-- Center content -->
        <div class="relative z-10 hero-text flex flex-col gap-6">
            <h1 class="text-4xl font-bold leading-snug max-w-xs">
                Welcome back to your real estate hub.
            </h1>
            <p class="text-white/60 text-sm max-w-xs leading-relaxed">
                Pick up right where you left off — your listings, clients, and properties are waiting.
            </p>

            <!-- Stats row -->
            <div class="flex gap-3 mt-2">
                <div class="stat-card text-center">
                    <div class="text-2xl font-bold text-violet-300">12k+</div>
                    <div class="text-xs text-white/50 mt-0.5">Properties Listed</div>
                </div>
                <div class="stat-card text-center">
                    <div class="text-2xl font-bold text-violet-300">4.8★</div>
                    <div class="text-xs text-white/50 mt-0.5">Average Rating</div>
                </div>
                <div class="stat-card text-center">
                    <div class="text-2xl font-bold text-violet-300">98%</div>
                    <div class="text-xs text-white/50 mt-0.5">Client Satisfaction</div>
                </div>
            </div>

            <!-- Testimonial -->
            <div class="testimonial-card max-w-xs">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-9 h-9 rounded-full bg-violet-500 flex items-center justify-center text-sm font-bold">R
                    </div>
                    <div>
                        <div class="text-sm font-semibold">Rahul Sharma</div>
                        <div class="text-xs text-white/50">Agent · Mumbai</div>
                    </div>
                    <div class="ml-auto text-yellow-400 text-xs">★★★★★</div>
                </div>
                <p class="text-xs text-white/60 leading-relaxed">
                    "This platform completely changed how I manage my listings. Everything in one place — it's a game
                    changer."
                </p>
            </div>
        </div>
    </div>

    <!-- RIGHT: Form Panel -->
    <div class="flex items-center justify-center bg-gray-50 w-full md:w-[480px] min-h-screen p-6">
        <div class="bg-white rounded-3xl shadow-2xl shadow-violet-100 p-8 w-full max-w-md card-enter">

            <!-- Icon -->
            <div class="w-11 h-11 rounded-2xl bg-violet-100 flex items-center justify-center mb-5">
                <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
            </div>

            <!-- Heading -->
            <h2 class="text-2xl font-bold text-gray-900 mb-1" style="font-family:'Playfair Display',serif">Welcome Back
            </h2>
            <p class="text-gray-400 text-sm mb-7 leading-relaxed">Sign in to your account to continue managing
                properties and clients.</p>

            <!-- Form -->
            <form action="/user/sign-in" method="POST" class="space-y-4">
                <!-- Email -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1.5">Email</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </span>
                        <input name="email" type="email" placeholder="Enter your email"
                            class="field-input w-full border border-gray-200 rounded-xl pl-10 pr-4 py-3 text-sm text-gray-800 placeholder-gray-300 transition-all bg-gray-50 focus:bg-white" />
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <div class="flex items-center justify-between mb-1.5">
                        <label class="text-xs font-medium text-gray-600">Password</label>
                        <a href="#" class="text-xs text-violet-600 hover:underline font-medium">Forgot password?</a>
                    </div>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </span>
                        <input name="password" type="password" id="password" placeholder="Enter your password"
                            class="field-input w-full border border-gray-200 rounded-xl pl-10 pr-10 py-3 text-sm text-gray-800 placeholder-gray-300 transition-all bg-gray-50 focus:bg-white" />
                        <button onclick="togglePwd()"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-violet-500 transition">
                            <svg id="eye-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                </div>
            
                <!-- Remember Me -->
                <div class="flex items-center gap-2">
                    <input name="remember" type="checkbox" id="remember" class="w-4 h-4 rounded border-gray-300 cursor-pointer" />
                    <label for="remember" class="text-xs text-gray-500 cursor-pointer select-none">Remember me for 30
                        days</label>
                </div>

                <!-- Sign In Button -->
                <button
                    class="btn-signin w-full text-white font-semibold py-3.5 rounded-xl text-sm mt-1 cursor-pointer">
                    Sign In
                </button>

                <!-- Divider -->
                <div class="or-divider">or continue with</div>

                <!-- Social Buttons -->
                <div class="grid grid-cols-2 gap-3">
                    <button
                        class="social-btn flex items-center justify-center gap-2 py-3 rounded-xl text-sm text-gray-700 font-medium bg-white cursor-pointer">
                        <svg class="w-4 h-4" viewBox="0 0 24 24">
                            <path fill="#4285F4"
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                            <path fill="#34A853"
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="#FBBC05"
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                            <path fill="#EA4335"
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                        Google
                    </button>
                    <button
                        class="social-btn flex items-center justify-center gap-2 py-3 rounded-xl text-sm text-gray-700 font-medium bg-white cursor-pointer">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
                        </svg>
                        Apple
                    </button>
                </div>

                <!-- Sign Up link -->
                <p class="text-center text-xs text-gray-400 mt-2">
                    Don't have an account?
                    <a href="/user/sign-up-page" class="text-violet-600 font-semibold hover:underline">Sign Up</a>
                </p>
            </form>
    </div>
    </div>

    <script>
        function togglePwd() {
            const inp = document.getElementById('password');
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>

</html>